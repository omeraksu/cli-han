generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id              String        @id @db.VarChar(64)
  streamerWallet  String        @db.VarChar(42)
  wsToken         String?       @db.VarChar(64)
  startedAt       DateTime
  endedAt         DateTime?
  totalViewers    Int           @default(0)
  totalTipsWei    Decimal       @default(0) @db.Decimal(78, 0)
  chatMessages    ChatMessage[]
  tips            Tip[]
  room            Room?         @relation(fields: [roomId], references: [id])
  roomId          String?       @unique @db.VarChar(64)
  // Sprint 1 (events layer): null for B2C sessions, set for event-attached
  // streams. teamLabel is a free-form text for V1 (no Team table yet).
  event           Event?        @relation(fields: [eventId], references: [id])
  eventId         String?       @db.Uuid
  teamLabel       String?       @db.VarChar(64)
  @@index([eventId])
  @@map("sessions")
}

model Room {
  id           String        @id @db.VarChar(64)
  kind         String        @db.VarChar(16)
  slug         String        @unique @db.VarChar(64)
  title        String        @db.VarChar(128)
  ownerWallet  String?       @db.VarChar(42)
  createdAt    DateTime      @default(now())
  endedAt      DateTime?
  metadata     Json?
  chatMessages ChatMessage[]
  session      Session?
  @@map("rooms")
}

model Profile {
  wallet       String   @id @db.VarChar(42)
  handle       String   @unique @db.VarChar(32)
  bio          String?
  // Sprint 2 — organizer/judge web dashboard login. Builder still wallet-only.
  email        String?  @unique @db.VarChar(128)
  ssoProvider  String?  @db.VarChar(16)
  ssoSubject   String?  @db.VarChar(128)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  eventMembers  EventMember[]
  teamMembers   TeamMember[]
  attestations  BuilderAttestation[]
  @@unique([ssoProvider, ssoSubject])
  @@map("profiles")
}

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String?  @db.VarChar(64)
  roomId     String?  @db.VarChar(64)
  userWallet String   @db.VarChar(42)
  content    String
  createdAt  DateTime @default(now())
  session    Session? @relation(fields: [sessionId], references: [id])
  room       Room?    @relation(fields: [roomId], references: [id])
  @@map("chat_messages")
}

model Tip {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @db.VarChar(64)
  roomId      String?  @db.VarChar(64)
  fromWallet  String   @db.VarChar(42)
  toWallet    String   @db.VarChar(42)
  amountWei   Decimal  @db.Decimal(78, 0)
  feeWei      Decimal  @default(0) @db.Decimal(78, 0)
  streamerWei Decimal  @default(0) @db.Decimal(78, 0)
  txHash      String   @db.VarChar(66)
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id])
  @@map("tips")
}

// Sprint 1 — minimum events delta for Build Corpus Report MVP.
// Full Event/Team/Member/Role/HelpSignal tables land in Sprint 2.
model Event {
  id              String       @id @default(uuid()) @db.Uuid
  slug            String       @unique @db.VarChar(64)
  title           String       @db.VarChar(128)
  organizerWallet String       @db.VarChar(42)
  startsAt        DateTime
  endsAt          DateTime?
  status          String       @default("draft") @db.VarChar(16)
  plan            String       @default("corpus-report") @db.VarChar(32)
  brand           Json?
  createdAt       DateTime     @default(now())
  sessions        Session[]
  submissions     Submission[]
  reports         CorpusReport[]
  members         EventMember[]
  teams           Team[]
  helpSignals     HelpSignal[]
  attestations    BuilderAttestation[]
  @@map("events")
}

// Sprint 2 — event-scoped role binding. role enum stored as VarChar for now
// (organizer/judge/mentor/instructor/builder/spectator).
model EventMember {
  id          String   @id @default(uuid()) @db.Uuid
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String   @db.Uuid
  profile     Profile  @relation(fields: [wallet], references: [wallet])
  wallet      String   @db.VarChar(42)
  role        String   @db.VarChar(16)
  invitedBy   String?  @db.VarChar(42)
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())
  @@unique([eventId, wallet])
  @@index([eventId])
  @@map("event_members")
}

model Team {
  id          String       @id @default(uuid()) @db.Uuid
  event       Event        @relation(fields: [eventId], references: [id])
  eventId     String       @db.Uuid
  slug        String       @db.VarChar(64)
  name        String       @db.VarChar(128)
  status      String       @default("active") @db.VarChar(16)
  createdAt   DateTime     @default(now())
  members     TeamMember[]
  submissions Submission[]
  helpSignals HelpSignal[]
  @@unique([eventId, slug])
  @@index([eventId])
  @@map("teams")
}

model TeamMember {
  id          String   @id @default(uuid()) @db.Uuid
  team        Team     @relation(fields: [teamId], references: [id])
  teamId      String   @db.Uuid
  profile     Profile  @relation(fields: [wallet], references: [wallet])
  wallet      String   @db.VarChar(42)
  role        String   @default("member") @db.VarChar(16)
  createdAt   DateTime @default(now())
  @@unique([teamId, wallet])
  @@index([teamId])
  @@map("team_members")
}

model Submission {
  id            String   @id @default(uuid()) @db.Uuid
  event         Event    @relation(fields: [eventId], references: [id])
  eventId       String   @db.Uuid
  team          Team?    @relation(fields: [teamId], references: [id])
  teamId        String?  @db.Uuid
  // teamLabel persists for B2C / pre-team-table corpus events (Sprint 1 path).
  teamLabel     String   @db.VarChar(64)
  title         String   @db.VarChar(128)
  summary       String?
  repoUrl       String?  @db.VarChar(256)
  demoUrl       String?  @db.VarChar(256)
  anchorTxHash  String?  @db.VarChar(66)
  submittedAt   DateTime @default(now())
  @@index([eventId])
  @@index([teamId])
  @@map("submissions")
}

model HelpSignal {
  id          String    @id @default(uuid()) @db.Uuid
  event       Event     @relation(fields: [eventId], references: [id])
  eventId     String    @db.Uuid
  team        Team?     @relation(fields: [teamId], references: [id])
  teamId      String?   @db.Uuid
  // sessionId is the Session.id of the builder asking for help.
  sessionId   String    @db.VarChar(64)
  reason      String?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  resolvedBy  String?   @db.VarChar(42)
  @@index([eventId])
  @@index([teamId])
  @@map("help_signals")
}

// Sprint 6 will wire this to HanEventAnchor.sol. For now anchorTxHash stays
// null and rows are written from the WS attestation handler.
model BuilderAttestation {
  id           String   @id @default(uuid()) @db.Uuid
  event        Event    @relation(fields: [eventId], references: [id])
  eventId      String   @db.Uuid
  profile      Profile  @relation(fields: [wallet], references: [wallet])
  wallet       String   @db.VarChar(42)
  role         String   @db.VarChar(16)
  anchorTxHash String?  @db.VarChar(66)
  attestedAt   DateTime @default(now())
  @@unique([eventId, wallet])
  @@index([eventId])
  @@map("builder_attestations")
}

model CorpusReport {
  id          String   @id @default(uuid()) @db.Uuid
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String   @db.Uuid
  status      String   @default("queued") @db.VarChar(16)
  frictionMap Json?
  pdfPath     String?  @db.VarChar(256)
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  @@index([eventId])
  @@map("corpus_reports")
}

model GameResult {
  id        String   @id @default(uuid()) @db.Uuid
  gameType  String   @db.VarChar(32)
  gameId    BigInt
  players   Json
  winner    String   @db.VarChar(42)
  stakeWei  Decimal  @db.Decimal(78, 0)
  potWei    Decimal  @db.Decimal(78, 0)
  roomId    String?  @db.VarChar(64)
  settledTx String?  @db.VarChar(66)
  createdAt DateTime @default(now())
  @@map("game_results")
}
