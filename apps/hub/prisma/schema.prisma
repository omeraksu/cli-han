generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                String       @id @db.VarChar(64)
  streamerWallet    String       @db.VarChar(64)
  wsToken           String?      @db.VarChar(64)
  startedAt         DateTime
  endedAt           DateTime?
  totalViewers      Int          @default(0)
  totalTipsLamports BigInt       @default(0)
  chatMessages      ChatMessage[]
  tips              Tip[]
  @@map("sessions")
}

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @db.VarChar(64)
  userWallet String   @db.VarChar(64)
  content    String
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id])
  @@map("chat_messages")
}

model Tip {
  id                String   @id @default(uuid()) @db.Uuid
  sessionId         String   @db.VarChar(64)
  fromWallet        String   @db.VarChar(64)
  toWallet          String   @db.VarChar(64)
  amountLamports    BigInt
  feeLamports       BigInt   @default(0)
  streamerLamports  BigInt   @default(0)
  txSignature       String   @db.VarChar(128)
  createdAt         DateTime @default(now())
  session           Session  @relation(fields: [sessionId], references: [id])
  @@map("tips")
}

model GameResult {
  id             String   @id @default(uuid()) @db.Uuid
  gameType       String   @db.VarChar(32)
  gameId         BigInt
  players        Json
  winner         String   @db.VarChar(64)
  stakeLamports  BigInt
  potLamports    BigInt
  attestationPda String?  @db.VarChar(64)
  attestationTx  String?  @db.VarChar(128)
  settledTx      String?  @db.VarChar(128)
  createdAt      DateTime @default(now())
  @@map("game_results")
}

model Attestation {
  id          String   @id @default(uuid()) @db.Uuid
  type        String   @db.VarChar(32)
  payload     Json
  pda         String   @db.VarChar(64)
  txSignature String   @db.VarChar(128)
  createdAt   DateTime @default(now())
  @@map("attestations")
}
