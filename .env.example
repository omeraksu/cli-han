# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Helius (ikincil RPC, demo öncesi al — ücretsiz tier yeterli)
HELIUS_API_KEY=
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=

# Hub authority keypair (base58 encoded, devnet: ~/.config/solana/id.json'dan)
HUB_AUTHORITY_KEYPAIR=

# Han Anchor program (anchor deploy sonrası doldur)
HAN_PROGRAM_ID=

# SAS (npx tsx scripts/setup-sas.ts sonrası doldur)
SAS_CREDENTIAL_PDA=
SAS_SCHEMA_PDA=

# Hub backend
HUB_PORT=3000
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://han:han@localhost:5432/han

# Anthropic (summarizer için)
ANTHROPIC_API_KEY=
