# Avalanche
AVAX_NETWORK=fuji
AVAX_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVAX_RPC_FALLBACK_URLS=https://avalanche-fuji-c-chain-rpc.publicnode.com,https://avalanche-fuji.drpc.org

# Hub authority private key (hex, used to settle game escrow)
HUB_AUTHORITY_PRIVATE_KEY=

# Han game escrow contract (set after forge script DeployFuji)
HAN_CONTRACT_ADDRESS=

# HanTipRouter atomic tip splitter (set after forge script DeployFuji)
HAN_TIP_ROUTER_ADDRESS=

# Fee receiver (wallet that gets the 3% protocol cut)
HAN_FEE_RECEIVER_ADDRESS=

# Snowtrace verification (optional, for `forge script --verify`)
SNOWTRACE_API_KEY=

# Hub backend
HUB_PORT=3000
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://han:han@localhost:5432/han_avax

# Local wallet path (default ~/.config/han-avax/wallet.json)
HAN_WALLET_PATH=

# Anthropic (summarizer için)
ANTHROPIC_API_KEY=
